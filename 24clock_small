<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Apple Watch 24H Clock</title>
<style>
body {
    /* 有機ELディスプレイのバッテリー節約のため完全な黒に設定 */
    background: black; 
    color: white;
    margin: 0;
    height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    /* Apple Watchのシステムフォントを使用 */
    font-family: -apple-system, sans-serif;
    overflow: hidden; /* 画面スクロールを防ぐ */
}

#digital {
    font-size: 16px;
    margin-bottom: 8px;
    font-weight: bold;
}

.clock {
    /* 画面幅に合わせて自動でサイズを調整します */
    width: 85vw;
    height: 85vw;
    max-width: 170px;
    max-height: 170px;
    border-radius: 50%;
    position: relative;
    border: 4px solid #00ffc3;
    overflow: hidden;
    background-color: #0a0a2a;
}

#bg {
    position: absolute;
    width: 100%;
    height: 100%;
}

.number {
    position: absolute;
    transform: translate(-50%, -50%);
    font-size: 11px;
    font-weight: bold;
    z-index: 10;
}

.hand {
    position: absolute;
    width: 3px;
    height: 45%;
    background: red;
    top: 50%;
    left: 50%;
    transform-origin: bottom center;
    z-index: 20;
}

.center {
    position: absolute;
    width: 8px;
    height: 8px;
    background: white;
    border-radius: 50%;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 30;
}

.marker {
    position: absolute;
    transform: translate(-50%, -50%);
    font-size: 9px;
    color: yellow;
    background: rgba(0,0,0,0.6);
    padding: 1px 3px;
    border-radius: 3px;
    z-index: 10;
}
</style>
</head>
<body>

<div id="digital"></div>

<div class="clock" id="clock">
    <div id="bg"></div>
    <div class="hand" id="hand"></div>
    <div class="center"></div>
</div>

<script>
const clock = document.getElementById("clock");

function angleFromHour(hour) {
    return (hour - 12) * 15;
}

// 数字の配置（パーセンテージで計算し、画面サイズに自動追従させます）
for (let i = 0; i < 24; i++) {
    const angle = angleFromHour(i);
    const rad = (angle - 90) * Math.PI / 180;
    const r = 40; // 半径を40%に設定
    const x = 50 + r * Math.cos(rad);
    const y = 50 + r * Math.sin(rad);

    const el = document.createElement("div");
    el.className = "number";
    el.style.left = x + "%";
    el.style.top = y + "%";
    el.textContent = i;
    clock.appendChild(el);
}

function getSunTimes(date) {
    const day = Math.floor((date - new Date(date.getFullYear(), 0, 0)) / 86400000);
    const dayLength = 12 + 2.5 * Math.sin((day - 80) / 365 * 2 * Math.PI);
    const sunrise = 12 - dayLength / 2;
    const sunset  = 12 + dayLength / 2;
    return { sunrise, sunset };
}

function drawMarker(hour, label) {
    const angle = angleFromHour(hour);
    const rad = (angle - 90) * Math.PI / 180;
    const r = 28; // マーカーの半径を28%に設定
    const x = 50 + r * Math.cos(rad);
    const y = 50 + r * Math.sin(rad);

    const m = document.createElement("div");
    m.className = "marker";
    m.style.left = x + "%";
    m.style.top = y + "%";
    m.textContent = label;
    clock.appendChild(m);
}

const { sunrise, sunset } = getSunTimes(new Date());
// 文字が重ならないように短く表記
drawMarker(sunrise, "日出");
drawMarker(sunset, "日没");

function update() {
    const now = new Date();
    const h = now.getHours();
    const m = now.getMinutes();
    const s = now.getSeconds();
    const decimalTime = h + m/60 + s/3600;

    document.getElementById("digital").textContent =
        `${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;

    const handAngle = angleFromHour(decimalTime);
    document.getElementById("hand").style.transform =
        `translate(-50%, -100%) rotate(${handAngle}deg)`;

    const startDeg = sunrise * 15;
    const endDeg = sunset * 15;

    document.getElementById("bg").style.background =
        `conic-gradient(
            from 180deg,
            #0a0a2a 0deg,
            #0a0a2a ${startDeg}deg,
            #4a90e2 ${startDeg}deg,
            #4a90e2 ${endDeg}deg,
            #0a0a2a ${endDeg}deg,
            #0a0a2a 360deg
        )`;
}

setInterval(update, 1000);
update();
</script>

</body>
</html>
